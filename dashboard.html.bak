<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mission Control v2.2 - Smart Cascade Router</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg-primary: #0a0a0f;
      --bg-secondary: #12121a;
      --bg-tertiary: #1a1a25;
      --accent: #6366f1;
      --accent-glow: rgba(99, 102, 241, 0.3);
      --success: #22c55e;
      --warning: #f59e0b;
      --danger: #ef4444;
      --text-primary: #f1f5f9;
      --text-secondary: #94a3b8;
      --border: #27273a;
      --mlx: #f59e0b;
      --kimi-code: #8b5cf6;
      --kimi: #06b6d4;
      --minimax: #ec4899;
      --nano: #10b981;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg-primary);
      color: var(--text-primary);
      min-height: 100vh;
    }

    .container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 20px;
    }

    /* Header */
    .header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 20px 0;
      border-bottom: 1px solid var(--border);
      margin-bottom: 30px;
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .logo-icon {
      width: 44px;
      height: 44px;
      background: linear-gradient(135deg, var(--accent), #8b5cf6);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 24px;
    }

    .logo h1 {
      font-size: 24px;
      font-weight: 700;
      background: linear-gradient(135deg, var(--text-primary), var(--accent));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .logo span {
      font-size: 12px;
      color: var(--text-secondary);
      font-weight: 500;
    }

    .header-stats {
      display: flex;
      gap: 24px;
    }

    .stat {
      text-align: center;
    }

    .stat-value {
      font-size: 20px;
      font-weight: 700;
      color: var(--success);
    }

    .stat-label {
      font-size: 11px;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    /* Navigation */
    .nav {
      display: flex;
      gap: 8px;
      margin-bottom: 24px;
      background: var(--bg-secondary);
      padding: 6px;
      border-radius: 12px;
      width: fit-content;
    }

    .nav-btn {
      padding: 10px 20px;
      border: none;
      background: transparent;
      color: var(--text-secondary);
      font-size: 14px;
      font-weight: 500;
      border-radius: 8px;
      cursor: pointer;
      transition: all 0.2s;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .nav-btn:hover {
      color: var(--text-primary);
      background: var(--bg-tertiary);
    }

    .nav-btn.active {
      background: var(--accent);
      color: white;
    }

    /* Content Sections */
    .content {
      display: none;
    }

    .content.active {
      display: block;
      animation: fadeIn 0.3s ease;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* Cards */
    .card {
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 24px;
      margin-bottom: 24px;
    }

    .card-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 20px;
    }

    .card-title {
      font-size: 18px;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    /* Cascade Routing Flow */
    .cascade-flow {
      display: flex;
      flex-direction: column;
      gap: 16px;
      padding: 20px;
      background: var(--bg-tertiary);
      border-radius: 12px;
      margin: 20px 0;
    }

    .cascade-step {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 16px;
      background: var(--bg-secondary);
      border-radius: 12px;
      border: 2px solid transparent;
      transition: all 0.2s;
    }

    .cascade-step:hover {
      border-color: var(--accent);
    }

    .cascade-step.primary {
      border-color: var(--mlx);
      background: rgba(245, 158, 11, 0.1);
    }

    .cascade-step.escalation {
      border-color: var(--kimi-code);
      background: rgba(139, 92, 246, 0.1);
    }

    .step-number {
      width: 32px;
      height: 32px;
      background: var(--accent);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 14px;
      flex-shrink: 0;
    }

    .step-content {
      flex: 1;
    }

    .step-title {
      font-weight: 600;
      margin-bottom: 4px;
    }

    .step-desc {
      font-size: 13px;
      color: var(--text-secondary);
    }

    .step-model {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 8px 16px;
      background: var(--bg-tertiary);
      border-radius: 8px;
      font-size: 13px;
    }

    .step-model .cost-free {
      color: var(--success);
      font-weight: 600;
    }

    .step-model .cost-paid {
      color: var(--warning);
      font-weight: 600;
    }

    .arrow-down {
      text-align: center;
      color: var(--text-secondary);
      font-size: 20px;
    }

    /* Routing Stats */
    .routing-stats {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 16px;
      margin-top: 20px;
    }

    .routing-stat {
      text-align: center;
      padding: 16px;
      background: var(--bg-tertiary);
      border-radius: 12px;
    }

    .routing-stat-value {
      font-size: 28px;
      font-weight: 700;
      margin-bottom: 4px;
    }

    .routing-stat-value.mlx { color: var(--mlx); }
    .routing-stat-value.escalation { color: var(--kimi-code); }
    .routing-stat-value.direct { color: var(--minimax); }

    .routing-stat-label {
      font-size: 12px;
      color: var(--text-secondary);
    }

    /* Agent Grid */
    .agent-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 16px;
    }

    .agent-card {
      background: var(--bg-tertiary);
      border: 2px solid var(--border);
      border-radius: 12px;
      padding: 20px;
      transition: all 0.2s;
      position: relative;
    }

    .agent-card:hover {
      transform: translateY(-2px);
      border-color: var(--accent);
    }

    .agent-card.primary {
      border-color: var(--mlx);
      box-shadow: 0 0 20px rgba(245, 158, 11, 0.2);
    }

    .agent-card.escalation {
      border-color: var(--kimi-code);
    }

    .agent-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 12px;
    }

    .agent-name {
      display: flex;
      align-items: center;
      gap: 10px;
      font-weight: 600;
    }

    .agent-emoji {
      font-size: 24px;
    }

    .agent-cost {
      padding: 4px 10px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
    }

    .agent-cost.free {
      background: rgba(34, 197, 94, 0.2);
      color: var(--success);
    }

    .agent-cost.low {
      background: rgba(245, 158, 11, 0.2);
      color: var(--warning);
    }

    .agent-cost.medium {
      background: rgba(236, 72, 153, 0.2);
      color: #ec4899;
    }

    .agent-role {
      font-size: 12px;
      color: var(--accent);
      margin-bottom: 8px;
    }

    .agent-desc {
      font-size: 13px;
      color: var(--text-secondary);
      line-height: 1.5;
      margin-bottom: 12px;
    }

    .agent-stats {
      display: flex;
      gap: 16px;
      padding-top: 12px;
      border-top: 1px solid var(--border);
    }

    .agent-stat {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 13px;
    }

    .status-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
    }

    .status-dot.online {
      background: var(--success);
      box-shadow: 0 0 8px var(--success);
    }

    /* Goals */
    .goals-grid {
      display: grid;
      gap: 16px;
    }

    .goal-card {
      background: var(--bg-tertiary);
      border-radius: 12px;
      padding: 20px;
      display: grid;
      grid-template-columns: 50px 1fr auto;
      gap: 16px;
      align-items: center;
    }

    .goal-icon {
      width: 50px;
      height: 50px;
      background: linear-gradient(135deg, var(--accent), #8b5cf6);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 24px;
    }

    .goal-info h3 {
      font-size: 16px;
      font-weight: 600;
      margin-bottom: 4px;
    }

    .goal-meta {
      display: flex;
      gap: 16px;
      font-size: 13px;
      color: var(--text-secondary);
    }

    .goal-meta span {
      display: flex;
      align-items: center;
      gap: 4px;
    }

    .goal-progress {
      text-align: right;
    }

    .progress-ring {
      width: 60px;
      height: 60px;
      position: relative;
    }

    .progress-ring svg {
      transform: rotate(-90deg);
    }

    .progress-ring-bg {
      fill: none;
      stroke: var(--border);
      stroke-width: 4;
    }

    .progress-ring-fill {
      fill: none;
      stroke: var(--accent);
      stroke-width: 4;
      stroke-linecap: round;
      transition: stroke-dashoffset 0.5s ease;
    }

    .progress-text {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      font-size: 14px;
      font-weight: 700;
    }

    /* Tasks */
    .tasks-section {
      margin-bottom: 24px;
    }

    .section-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 16px;
    }

    .section-title {
      font-size: 16px;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .section-count {
      background: var(--accent);
      padding: 2px 10px;
      border-radius: 20px;
      font-size: 12px;
    }

    .task-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .task-item {
      display: grid;
      grid-template-columns: 1fr auto auto;
      gap: 16px;
      align-items: center;
      padding: 14px 16px;
      background: var(--bg-tertiary);
      border-radius: 10px;
      border-left: 3px solid var(--accent);
    }

    .task-item.completed {
      opacity: 0.6;
      border-left-color: var(--success);
    }

    .task-info h4 {
      font-size: 14px;
      font-weight: 500;
      margin-bottom: 4px;
    }

    .task-meta {
      display: flex;
      gap: 12px;
      font-size: 12px;
      color: var(--text-secondary);
    }

    .priority {
      padding: 2px 8px;
      border-radius: 4px;
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
    }

    .priority.high { background: rgba(239, 68, 68, 0.2); color: var(--danger); }
    .priority.medium { background: rgba(245, 158, 11, 0.2); color: var(--warning); }
    .priority.low { background: rgba(34, 197, 94, 0.2); color: var(--success); }

    /* Cost Dashboard */
    .cost-overview {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 16px;
      margin-bottom: 24px;
    }

    .cost-card {
      background: var(--bg-tertiary);
      border-radius: 12px;
      padding: 20px;
      text-align: center;
    }

    .cost-value {
      font-size: 32px;
      font-weight: 700;
      margin-bottom: 4px;
    }

    .cost-value.success { color: var(--success); }
    .cost-value.warning { color: var(--warning); }

    .cost-label {
      font-size: 13px;
      color: var(--text-secondary);
      margin-bottom: 12px;
    }

    .cost-bar {
      height: 6px;
      background: var(--border);
      border-radius: 3px;
      overflow: hidden;
    }

    .cost-bar-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--success), var(--accent));
      border-radius: 3px;
      transition: width 0.3s ease;
    }

    .cost-bar-fill.warning {
      background: linear-gradient(90deg, var(--warning), var(--danger));
    }

    /* Comparison */
    .comparison {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin: 20px 0;
    }

    .comparison-card {
      padding: 20px;
      border-radius: 12px;
      text-align: center;
    }

    .comparison-card.old {
      background: rgba(239, 68, 68, 0.1);
      border: 1px solid rgba(239, 68, 68, 0.3);
    }

    .comparison-card.new {
      background: rgba(34, 197, 94, 0.1);
      border: 1px solid rgba(34, 197, 94, 0.3);
    }

    .comparison-title {
      font-size: 13px;
      color: var(--text-secondary);
      margin-bottom: 8px;
    }

    .comparison-value {
      font-size: 24px;
      font-weight: 700;
    }

    .comparison-value.old { color: var(--danger); }
    .comparison-value.new { color: var(--success); }

    .savings-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 16px;
      background: rgba(34, 197, 94, 0.2);
      color: var(--success);
      border-radius: 20px;
      font-size: 14px;
      font-weight: 600;
      margin-top: 12px;
    }

    /* Toast */
    .toast {
      position: fixed;
      bottom: 24px;
      right: 24px;
      padding: 16px 24px;
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 12px;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
      display: none;
      align-items: center;
      gap: 12px;
      z-index: 1000;
      animation: slideIn 0.3s ease;
    }

    .toast.show {
      display: flex;
    }

    @keyframes slideIn {
      from { transform: translateX(100%); opacity: 0; }
      to { transform: translateX(0); opacity: 1; }
    }

    .toast-icon {
      font-size: 20px;
    }

    .toast.success .toast-icon { color: var(--success); }
    .toast.error .toast-icon { color: var(--danger); }

    /* Modal */
    .modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.8);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 1000;
      padding: 20px;
    }

    .modal-overlay.show {
      display: flex;
    }

    .modal {
      background: var(--bg-secondary);
      border-radius: 16px;
      max-width: 600px;
      width: 100%;
      max-height: 80vh;
      overflow: hidden;
      animation: modalIn 0.3s ease;
    }

    @keyframes modalIn {
      from { transform: scale(0.9); opacity: 0; }
      to { transform: scale(1); opacity: 1; }
    }

    .modal-header {
      padding: 20px 24px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .modal-title {
      font-size: 18px;
      font-weight: 600;
    }

    .modal-close {
      background: none;
      border: none;
      color: var(--text-secondary);
      font-size: 24px;
      cursor: pointer;
      padding: 4px;
    }

    .modal-body {
      padding: 24px;
      overflow-y: auto;
      max-height: 60vh;
    }

    .modal-footer {
      padding: 16px 24px;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: flex-end;
      gap: 12px;
    }

    .btn {
      padding: 10px 20px;
      border: none;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.2s;
    }

    .btn-primary {
      background: var(--accent);
      color: white;
    }

    .btn-primary:hover {
      background: #5558e0;
    }

    .btn-secondary {
      background: var(--bg-tertiary);
      color: var(--text-primary);
      border: 1px solid var(--border);
    }

    /* Memory */
    .memory-stats {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 16px;
      margin-bottom: 24px;
    }

    .memory-stat {
      background: var(--bg-tertiary);
      padding: 20px;
      border-radius: 12px;
      text-align: center;
    }

    .memory-stat-value {
      font-size: 28px;
      font-weight: 700;
      color: var(--accent);
    }

    .memory-stat-label {
      font-size: 12px;
      color: var(--text-secondary);
      margin-top: 4px;
    }

    .documents-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .document-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 14px;
      background: var(--bg-tertiary);
      border-radius: 10px;
      cursor: pointer;
      transition: all 0.2s;
    }

    .document-item:hover {
      background: var(--border);
    }

    .document-icon {
      width: 40px;
      height: 40px;
      background: var(--accent);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
    }

    .document-info {
      flex: 1;
    }

    .document-title {
      font-weight: 500;
      margin-bottom: 2px;
    }

    .document-meta {
      font-size: 12px;
      color: var(--text-secondary);
    }

    .document-chunks {
      background: var(--bg-secondary);
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 12px;
    }

    /* Search */
    .search-box {
      position: relative;
      margin-bottom: 20px;
    }

    .search-box input {
      width: 100%;
      padding: 14px 20px 14px 48px;
      background: var(--bg-tertiary);
      border: 1px solid var(--border);
      border-radius: 12px;
      color: var(--text-primary);
      font-size: 15px;
      outline: none;
      transition: all 0.2s;
    }

    .search-box input:focus {
      border-color: var(--accent);
    }

    .search-icon {
      position: absolute;
      left: 18px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text-secondary);
    }

    @media (max-width: 768px) {
      .header {
        flex-direction: column;
        gap: 20px;
        text-align: center;
      }

      .nav {
        flex-wrap: wrap;
        width: 100%;
      }

      .nav-btn {
        flex: 1;
        min-width: 100px;
        justify-content: center;
      }

      .goal-card {
        grid-template-columns: 1fr;
        text-align: center;
      }

      .goal-progress {
        display: flex;
        justify-content: center;
      }

      .task-item {
        grid-template-columns: 1fr;
        gap: 10px;
      }

      .task-meta {
        flex-wrap: wrap;
      }

      .comparison {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    <!-- Header -->
    <header class="header">
      <div class="logo">
        <div class="logo-icon">🎯</div>
        <div>
          <h1>Mission Control</h1>
          <span>v2.2 • Smart Cascade Router</span>
        </div>
      </div>
      <div class="header-stats">
        <div class="stat">
          <div class="stat-value" id="total-sessions">159</div>
          <div class="stat-label">Total Sessions</div>
        </div>
        <div class="stat">
          <div class="stat-value" id="total-cost">$1.47</div>
          <div class="stat-label">Week Cost</div>
        </div>
        <div class="stat">
          <div class="stat-value">$0.98</div>
          <div class="stat-label">Savings</div>
        </div>
      </div>
    </header>

    <!-- Navigation -->
    <nav class="nav">
      <button class="nav-btn active" data-tab="overview">
        <span>🏠</span> Overview
      </button>
      <button class="nav-btn" data-tab="routing">
        <span>🧠</span> Smart Routing
      </button>
      <button class="nav-btn" data-tab="agents">
        <span>🤖</span> Agents
      </button>
      <button class="nav-btn" data-tab="goals">
        <span>🎯</span> Goals
      </button>
      <button class="nav-btn" data-tab="tasks">
        <span>✓</span> Tasks
      </button>
      <button class="nav-btn" data-tab="costs">
        <span>💰</span> Costs
      </button>
      <button class="nav-btn" data-tab="memory">
        <span>🧠</span> Memory
      </button>
    </nav>

    <!-- Overview Tab -->
    <div class="content active" id="overview">
      <div class="card">
        <div class="card-header">
          <div class="card-title">🚀 Smart Cascade Router</div>
        </div>
        <p style="color: var(--text-secondary); margin-bottom: 20px;">
          <strong>New in v2.2:</strong> MLX-first routing with automatic escalation. Try the FREE model first, 
          only pay for complex tasks that actually need it.
        </p>
        
        <div class="cascade-flow">
          <div class="cascade-step">
            <div class="step-number">1</div>
            <div class="step-content">
              <div class="step-title">Quick Pre-filter</div>
              <div class="step-desc">Skip MLX for impossible tasks (images, Chinese text)</div>
            </div>
            <div class="step-model">
              <span>Direct Route</span>
            </div>
          </div>
          
          <div class="arrow-down">↓</div>
          
          <div class="cascade-step primary">
            <div class="step-number" style="background: var(--mlx);">2</div>
            <div class="step-content">
              <div class="step-title">🍎 MLX Attempts Task</div>
              <div class="step-desc">FREE local Apple Silicon model tries first</div>
            </div>
            <div class="step-model">
              <span class="cost-free">FREE</span>
            </div>
          </div>
          
          <div class="arrow-down">↓</div>
          
          <div class="cascade-step">
            <div class="step-number">3</div>
            <div class="step-content">
              <div class="step-title">Confidence Analysis</div>
              <div class="step-desc">Check MLX response quality and confidence indicators</div>
            </div>
            <div class="step-model">
              <span class="cost-free">Auto</span>
            </div>
          </div>
          
          <div class="arrow-down">↓</div>
          
          <div class="cascade-step escalation">
            <div class="step-number" style="background: var(--kimi-code);">4</div>
            <div class="step-content">
              <div class="step-title">Escalate if Needed</div>
              <div class="step-desc">💻 Kimi-Code for debugging, 🎯 Kimi 2.5 for reasoning</div>
            </div>
            <div class="step-model">
              <span class="cost-paid">$0.02</span>
            </div>
          </div>
        </div>

        <div class="routing-stats">
          <div class="routing-stat">
            <div class="routing-stat-value mlx">128</div>
            <div class="routing-stat-label">MLX Success (FREE)</div>
          </div>
          <div class="routing-stat">
            <div class="routing-stat-value escalation">14</div>
            <div class="routing-stat-label">Escalations ($0.28)</div>
          </div>
          <div class="routing-stat">
            <div class="routing-stat-value direct">5</div>
            <div class="routing-stat-label">Direct Routes ($0.08)</div>
          </div>
          <div class="routing-stat">
            <div class="routing-stat-value" style="color: var(--success);">36%</div>
            <div class="routing-stat-label">Cost Savings</div>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <div class="card-title">📊 Cost Comparison: Old vs New</div>
        </div>
        <div class="comparison">
          <div class="comparison-card old">
            <div class="comparison-title">Keyword-Based (Old)</div>
            <div class="comparison-value old">$0.36</div>
            <div style="font-size: 12px; color: var(--text-secondary); margin-top: 8px;">
              Predict upfront, no free attempts
            </div>
          </div>
          <div class="comparison-card new">
            <div class="comparison-title">MLX Cascade (New)</div>
            <div class="comparison-value new">$0.23</div>
            <div style="font-size: 12px; color: var(--text-secondary); margin-top: 8px;">
              MLX first, escalate if needed
            </div>
          </div>
        </div>
        <div style="text-align: center;">
          <span class="savings-badge">💰 Saving ~$15/month</span>
        </div>
      </div>
    </div>

    <!-- Routing Tab -->
    <div class="content" id="routing">
      <div class="card">
        <div class="card-header">
          <div class="card-title">🧠 Smart Routing Strategy</div>
        </div>
        
        <h4 style="margin-bottom: 16px;">How It Works</h4>
        <div class="cascade-flow">
          <div class="cascade-step primary">
            <div class="step-number" style="background: var(--success);">✓</div>
            <div class="step-content">
              <div class="step-title">MLX Attempts First (FREE)</div>
              <div class="step-desc">
                Simple tasks: code generation, basic debugging, file operations.<br>
                <strong>Cost: $0</strong> • <strong>Success Rate: 90%</strong>
              </div>
            </div>
            <div class="step-model">
              <span class="cost-free">$0</span>
            </div>
          </div>
          
          <div class="cascade-step escalation">
            <div class="step-number" style="background: var(--kimi-code);">↑</div>
            <div class="step-content">
              <div class="step-title">Escalate to Paid Models (if needed)</div>
              <div class="step-desc">
                • 💻 Kimi-Code: Complex debugging, architecture, refactoring<br>
                • 🎯 Kimi 2.5: Research, analysis, strategy, reasoning<br>
                • 🎭 Minimax: Images, Chinese (direct route - MLX can't do these)
              </div>
            </div>
            <div class="step-model">
              <span class="cost-paid">$0.015-0.02</span>
            </div>
          </div>
        </div>

        <h4 style="margin: 24px 0 16px;">Escalation Triggers</h4>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 12px;">
          <div style="background: var(--bg-tertiary); padding: 16px; border-radius: 10px;">
            <div style="font-weight: 600; margin-bottom: 8px; color: var(--kimi-code);">💻 → Kimi-Code</div>
            <div style="font-size: 13px; color: var(--text-secondary);">
              debug, fix, error, refactor, optimize, architecture, memory leak, performance
            </div>
          </div>
          <div style="background: var(--bg-tertiary); padding: 16px; border-radius: 10px;">
            <div style="font-weight: 600; margin-bottom: 8px; color: var(--kimi);">🎯 → Kimi 2.5</div>
            <div style="font-size: 13px; color: var(--text-secondary);">
              research, analyze, study, plan, strategy, reasoning, investigate
            </div>
          </div>
          <div style="background: var(--bg-tertiary); padding: 16px; border-radius: 10px;">
            <div style="font-weight: 600; margin-bottom: 8px; color: var(--minimax);">🎭 → Minimax (Direct)</div>
            <div style="font-size: 13px; color: var(--text-secondary);">
              image, picture, photo, chinese, 中文, visual, generate image
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Agents Tab -->
    <div class="content" id="agents">
      <div class="card">
        <div class="card-header">
          <div class="card-title">🤖 AI Agents</div>
        </div>
        <div class="agent-grid" id="agent-grid"></div>
      </div>
    </div>

    <!-- Goals Tab -->
    <div class="content" id="goals">
      <div class="card">
        <div class="card-header">
          <div class="card-title">🎯 Goals</div>
        </div>
        <div class="goals-grid" id="goals-grid"></div>
      </div>
    </div>

    <!-- Tasks Tab -->
    <div class="content" id="tasks">
      <div class="card">
        <div class="section-header">
          <div class="section-title">
            ⚡ Active Tasks
            <span class="section-count" id="active-count">4</span>
          </div>
        </div>
        <div class="task-list" id="active-tasks"></div>
      </div>
      
      <div class="card">
        <div class="section-header">
          <div class="section-title">
            ✓ Completed
            <span class="section-count" id="completed-count">2</span>
          </div>
        </div>
        <div class="task-list" id="completed-tasks"></div>
      </div>
    </div>

    <!-- Costs Tab -->
    <div class="content" id="costs">
      <div class="card">
        <div class="card-header">
          <div class="card-title">💰 Cost Tracking</div>
        </div>
        <div class="cost-overview" id="cost-overview"></div>
        
        <h4 style="margin: 24px 0 16px;">Cost by Model</h4>
        <div class="documents-list" id="cost-by-model"></div>
      </div>
    </div>

    <!-- Memory Tab -->
    <div class="content" id="memory">
      <div class="card">
        <div class="card-header">
          <div class="card-title">🧠 Memory System</div>
        </div>
        
        <div class="memory-stats" id="memory-stats"></div>
        
        <div class="search-box">
          <span class="search-icon">🔍</span>
          <input type="text" placeholder="Search memory documents..." id="memory-search">
        </div>
        
        <h4 style="margin: 24px 0 16px;">Documents</h4>
        <div class="documents-list" id="documents-list"></div>
      </div>
    </div>
  </div>

  <!-- Toast -->
  <div class="toast" id="toast">
    <span class="toast-icon"></span>
    <span class="toast-message"></span>
  </div>

  <!-- Modal -->
  <div class="modal-overlay" id="modal">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-title" id="modal-title">Title</div>
        <button class="modal-close" onclick="closeModal()">&times;</button>
      </div>
      <div class="modal-body" id="modal-body">
        Content
      </div>
      <div class="modal-footer">
        <button class="btn btn-secondary" onclick="closeModal()">Close</button>
        <button class="btn btn-primary" onclick="closeModal()">OK</button>
      </div>
    </div>
  </div>

  <script>
    // Dashboard Data
    let dashboardData = null;

    // Initialize
    async function init() {
      try {
        const response = await fetch('dashboard-data.json');
        dashboardData = await response.json();
        renderAll();
        showToast('Dashboard loaded successfully', 'success');
      } catch (error) {
        showToast('Failed to load dashboard data', 'error');
        console.error('Failed to load data:', error);
      }
    }

    // Navigation
    document.querySelectorAll('.nav-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
        document.querySelectorAll('.content').forEach(c => c.classList.remove('active'));
        
        btn.classList.add('active');
        const tabId = btn.dataset.tab;
        document.getElementById(tabId).classList.add('active');
      });
    });

    // Render Functions
    function renderAll() {
      if (!dashboardData) return;
      
      renderAgents();
      renderGoals();
      renderTasks();
      renderCosts();
      renderMemory();
    }

    function renderAgents() {
      const grid = document.getElementById('agent-grid');
      if (!grid || !dashboardData?.agents) return;
      
      grid.innerHTML = dashboardData.agents.map(agent => {
        const isPrimary = agent.id === 'mlx';
        const isEscalation = ['kimi-code', 'kimi'].includes(agent.id);
        
        return `
          <div class="agent-card ${isPrimary ? 'primary' : ''} ${isEscalation ? 'escalation' : ''}">
            <div class="agent-header">
              <div class="agent-name">
                <span class="agent-emoji">${agent.emoji}</span>
                <span>${agent.name}</span>
              </div>
              <div class="agent-cost ${agent.costClass}">${agent.cost}</div>
            </div>
            <div class="agent-role">${agent.role}</div>
            <div class="agent-desc">${agent.description}</div>
            <div class="agent-stats">
              <div class="agent-stat">
                <span class="status-dot ${agent.status}"></span>
                <span>${agent.status}</span>
              </div>
              <div class="agent-stat">✓ ${agent.tasksCompleted} tasks</div>
              <div class="agent-stat">📊 ${agent.successRate}</div>
            </div>
          </div>
        `;
      }).join('');
    }

    function renderGoals() {
      const grid = document.getElementById('goals-grid');
      if (!grid || !dashboardData?.goals) return;
      
      grid.innerHTML = dashboardData.goals.map(goal => `
        <div class="goal-card" onclick="showGoalDetails(${goal.id})">
          <div class="goal-icon">${goal.agentIcon}</div>
          <div class="goal-info">
            <h3>${goal.name}</h3>
            <div class="goal-meta">
              <span>👤 ${goal.agent}</span>
              <span>📋 ${goal.tasks.completed}/${goal.tasks.total} tasks</span>
              <span>📅 ${goal.due}</span>
            </div>
          </div>
          <div class="goal-progress">
            <div class="progress-ring">
              <svg width="60" height="60" viewBox="0 0 60 60">
                <circle class="progress-ring-bg" cx="30" cy="30" r="26"></circle>
                <circle class="progress-ring-fill" cx="30" cy="30" r="26"
                  stroke-dasharray="163.36"
                  stroke-dashoffset="${163.36 - (163.36 * goal.progress / 100)}">
                </circle>
              </svg>
              <div class="progress-text">${goal.progress}%</div>
            </div>
          </div>
        </div>
      `).join('');
    }

    function renderTasks() {
      if (!dashboardData?.tasks) return;
      
      const activeList = document.getElementById('active-tasks');
      const completedList = document.getElementById('completed-tasks');
      
      if (activeList) {
        activeList.innerHTML = dashboardData.tasks.active.map(task => `
          <div class="task-item" onclick="showTaskDetails('${task.id}')">
            <div class="task-info">
              <h4>${task.name}</h4>
              <div class="task-meta">
                <span>👤 ${task.assignee}</span>
                <span>📅 ${task.due}</span>
              </div>
            </div>
            <span class="priority ${task.priority}">${task.priority}</span>
          </div>
        `).join('');
        
        document.getElementById('active-count').textContent = dashboardData.tasks.active.length;
      }
      
      if (completedList) {
        completedList.innerHTML = dashboardData.tasks.completed.map(task => `
          <div class="task-item completed" onclick="showTaskDetails('${task.id}')">
            <div class="task-info">
              <h4>${task.name}</h4>
              <div class="task-meta">
                <span>👤 ${task.assignee}</span>
                <span>✓ ${task.completedAt}</span>
              </div>
            </div>
          </div>
        `).join('');
        
        document.getElementById('completed-count').textContent = dashboardData.tasks.completed.length;
      }
    }

    function renderCosts() {
      if (!dashboardData?.costs) return;
      
      const overview = document.getElementById('cost-overview');
      if (overview) {
        const costs = dashboardData.costs;
        overview.innerHTML = `
          <div class="cost-card">
            <div class="cost-value success">$${costs.today}</div>
            <div class="cost-label">Today</div>
            <div class="cost-bar">
              <div class="cost-bar-fill" style="width: ${(costs.today / costs.budget.daily * 100).clamp(0, 100)}%"></div>
            </div>
          </div>
          <div class="cost-card">
            <div class="cost-value success">$${costs.week}</div>
            <div class="cost-label">This Week</div>
            <div class="cost-bar">
              <div class="cost-bar-fill" style="width: ${(costs.week / costs.budget.weekly * 100).clamp(0, 100)}%"></div>
            </div>
          </div>
          <div class="cost-card">
            <div class="cost-value warning">$${costs.month}</div>
            <div class="cost-label">This Month</div>
            <div class="cost-bar">
              <div class="cost-bar-fill warning" style="width: ${(costs.month / costs.budget.monthly * 100).clamp(0, 100)}%"></div>
            </div>
          </div>
        `;
      }
      
      const byModel = document.getElementById('cost-by-model');
      if (byModel && dashboardData.costs.byModel) {
        const modelData = dashboardData.costs.byModel;
        byModel.innerHTML = Object.entries(modelData).map(([key, data]) => `
          <div class="document-item">
            <div class="document-icon" style="font-size: 20px;">
              ${key === 'mlx' ? '🍎' : key === 'kimi-code' ? '💻' : key === 'kimi' ? '🎯' : key === 'minimax' ? '🎭' : '⚡'}
            </div>
            <div class="document-info">
              <div class="document-title">${key.toUpperCase()}</div>
              <div class="document-meta">${data.tasks} tasks</div>
            </div>
            <div class="document-chunks" style="background: ${data.cost === 0 ? 'rgba(34,197,94,0.2)' : 'rgba(245,158,11,0.2)'}; color: ${data.cost === 0 ? '#22c55e' : '#f59e0b'};">
              ${data.label}
            </div>
          </div>
        `).join('');
      }
    }

    function renderMemory() {
      if (!dashboardData?.memory) return;
      
      const stats = document.getElementById('memory-stats');
      if (stats) {
        stats.innerHTML = `
          <div class="memory-stat">
            <div class="memory-stat-value">${dashboardData.memory.totalDocuments}</div>
            <div class="memory-stat-label">Documents</div>
          </div>
          <div class="memory-stat">
            <div class="memory-stat-value">${dashboardData.memory.totalChunks}</div>
            <div class="memory-stat-label">Chunks</div>
          </div>
        `;
      }
      
      const docList = document.getElementById('documents-list');
      if (docList && dashboardData.memory.sources) {
        docList.innerHTML = dashboardData.memory.sources.map(doc => `
          <div class="document-item" onclick="showDocumentDetails('${doc.id}')">
            <div class="document-icon">📄</div>
            <div class="document-info">
              <div class="document-title">${doc.title}</div>
              <div class="document-meta">${doc.source} • Added ${doc.added}</div>
            </div>
            <div class="document-chunks">${doc.chunks} chunks</div>
          </div>
        `).join('');
      }
    }

    // Helper
    Number.prototype.clamp = function(min, max) {
      return Math.min(Math.max(this, min), max);
    };

    // Toast
    function showToast(message, type = 'success') {
      const toast = document.getElementById('toast');
      toast.className = `toast show ${type}`;
      toast.querySelector('.toast-icon').textContent = type === 'success' ? '✓' : '✕';
      toast.querySelector('.toast-message').textContent = message;
      
      setTimeout(() => toast.classList.remove('show'), 3000);
    }

    // Modal
    function showModal(title, content) {
      document.getElementById('modal-title').textContent = title;
      document.getElementById('modal-body').innerHTML = content;
      document.getElementById('modal').classList.add('show');
    }

    function closeModal() {
      document.getElementById('modal').classList.remove('show');
    }

    // Detail Views
    function showGoalDetails(goalId) {
      const goal = dashboardData.goals.find(g => g.id === goalId);
      if (!goal) return;
      
      showModal(goal.name, `
        <div style="display: grid; gap: 16px;">
          <div>
            <strong>Progress:</strong> ${goal.progress}%
            <div style="background: var(--border); height: 8px; border-radius: 4px; margin-top: 8px;">
              <div style="background: var(--accent); height: 100%; width: ${goal.progress}%; border-radius: 4px;"></div>
            </div>
          </div>
          <div><strong>Status:</strong> ${goal.status}</div>
          <div><strong>Assigned Agent:</strong> ${goal.agentIcon} ${goal.agent}</div>
          <div><strong>Tasks:</strong> ${goal.tasks.completed}/${goal.tasks.total} completed</div>
          <div><strong>Due Date:</strong> ${goal.due}</div>
        </div>
      `);
    }

    function showTaskDetails(taskId) {
      const allTasks = [...dashboardData.tasks.active, ...dashboardData.tasks.completed];
      const task = allTasks.find(t => t.id === taskId);
      if (!task) return;
      
      showModal(task.name, `
        <div style="display: grid; gap: 12px;">
          <div><strong>ID:</strong> ${task.id}</div>
          <div><strong>Assignee:</strong> ${task.assignee}</div>
          ${task.priority ? `<div><strong>Priority:</strong> <span class="priority ${task.priority}">${task.priority}</span></div>` : ''}
          ${task.due ? `<div><strong>Due:</strong> ${task.due}</div>` : ''}
          ${task.completedAt ? `<div><strong>Completed:</strong> ${task.completedAt}</div>` : ''}
        </div>
      `);
    }

    function showDocumentDetails(docId) {
      const doc = dashboardData.memory.sources.find(d => d.id === docId);
      if (!doc) return;
      
      showModal(doc.title, `
        <div style="display: grid; gap: 12px;">
          <div><strong>ID:</strong> ${doc.id}</div>
          <div><strong>Source:</strong> ${doc.source}</div>
          <div><strong>Added:</strong> ${doc.added}</div>
          <div><strong>Chunks:</strong> ${doc.chunks}</div>
        </div>
      `);
    }

    // Search
    document.getElementById('memory-search')?.addEventListener('input', (e) => {
      const query = e.target.value.toLowerCase();
      const items = document.querySelectorAll('#documents-list .document-item');
      
      items.forEach(item => {
        const text = item.textContent.toLowerCase();
        item.style.display = text.includes(query) ? 'flex' : 'none';
      });
    });

    // Close modal on overlay click
    document.getElementById('modal')?.addEventListener('click', (e) => {
      if (e.target.id === 'modal') closeModal();
    });

    // Start
    init();
  </script>
</body>
</html>
