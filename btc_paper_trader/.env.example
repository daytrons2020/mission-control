# Binance Testnet API Credentials
# Get these from: https://testnet.binance.vision/

BINANCE_TESTNET_API_KEY=your_api_key_here
BINANCE_TESTNET_SECRET_KEY=your_secret_key_here

# Trading Configuration
TRADING_SYMBOL=BTCUSDT
TIMEFRAME=1h

# Risk Management
RISK_PER_TRADE=0.01
MAX_OPEN_POSITIONS=1
MAX_DAILY_LOSS=0.05
MAX_POSITION_SIZE=0.1

# Strategy Parameters - EMA Crossover + RSI
EMA_FAST=9
EMA_SLOW=21
RSI_PERIOD=14
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30

# ATR Parameters for Stop Loss and Take Profit
ATR_PERIOD=14
ATR_MULTIPLIER_SL=1.5
ATR_MULTIPLIER_TP=3.0

# Trading Hours (24h format, UTC)
TRADING_START_HOUR=0
TRADING_END_HOUR=23

# Paper Trading Settings
PAPER_TRADING=true
INITIAL_BALANCE=10000

# Logging
LOG_LEVEL=INFO
LOG_TO_FILE=true

# Database
DATABASE_URL=sqlite:///data/trades.db

# Dashboard
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=5000
