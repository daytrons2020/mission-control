{
  "version": 2,
  "name": "mission-control",
  "builds": [
    {
      "src": "dashboard.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/dashboard.html"
    },
    {
      "src": "/api/status",
      "dest": "/api/status.js"
    },
    {
      "src": "/api/projects",
      "dest": "/api/projects.js"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=300, stale-while-revalidate"
        }
      ]
    }
  ],
  "env": {
    "DISCORD_BOT_TOKEN": "@discord-bot-token",
    "DISCORD_GUILD_ID": "1474838650050314352"
  }
}
