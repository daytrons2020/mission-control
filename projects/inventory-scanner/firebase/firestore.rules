rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Items collection - inventory catalog
    match /items/{itemId} {
      allow read: if true;
      allow write: if true;
    }
    
    // Sessions collection - scanning sessions
    match /sessions/{sessionId} {
      allow read: if true;
      allow write: if true;
    }
  }
}